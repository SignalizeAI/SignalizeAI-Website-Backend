    "bcrypt": "^5.0.1",
    "dotenv": "^17.2.3",
    "next": "15.5.2",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.11",
    "stripe": "^14.7.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.19.33",
    "@types/nodemailer": "^6.4.14",
    "prisma": "^7.0.1",
